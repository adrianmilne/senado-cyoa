      "id": "conditional_scene",
      "type": "normal",
      "title": "Conditional Scene",
      "text": "A locked door",
      "imagePrompt": {
        "subject": "Heavy iron-bound wooden door set into a crumbling stone wall, rusted lock",
        "mood": "oppressive",
        "shot": "portrait"
      },
      "effectsOnEntry": [],
      "choices": [
        {
          "id": "hidden_choice",
          "text": "Use the knife",
          "nextScene": "good_ending",
          "conditions": [
            {
              "type": "has_item",
              "key": "hunting_knife"
            }
          ],
          "effects": [],
          "hiddenIfConditionFails": true
        },
        {
          "id": "always_visible",
          "text": "Force the door",
          "nextScene": "combat_scene",
          "conditions": [],
          "effects": [
            {
              "type": "modify_stat",
              "key": "health",
              "value": -30
            }
          ]
        }
      ],
      "image": {
        "file": "images/conditional_scene.png",
        "altText": "Conditional Scene",
        "position": "top"
      }
    },
    "combat_scene": {
      "id": "combat_scene",
      "type": "combat",
      "title": "Combat",
      "text": "You are attacked",
      "imagePrompt": {
        "subject": "Hooded figure lunging from shadow, blade raised, narrow stone corridor",
        "mood": "dread",
        "shot": "wide",
        "exclude": "colour, bright light"
      },
      "effectsOnEntry": [
        {
          "type": "modify_stat",
          "key": "health",
          "value": -80
