{
  "id": "test_story",
  "title": "Engine Test Story",
  "author": "System",
  "version": "1.0.0",
  "description": "A short story that exercises all engine features.",
  "coverImage": "",
  "startScene": "start",
  "stateSchema": {
    "health": { "initial": 100, "min": 0, "max": 100 },
    "gold": { "initial": 10 },
    "flags": {
      "flag_a": false,
      "flag_b": false
    }
  },
  "scenes": {
    "start": {
      "id": "start",
      "type": "normal",
      "title": "Start",
      "text": "Beginning of test story",
      "effectsOnEntry": [],
